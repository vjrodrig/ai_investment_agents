# ─────────────────────────────────────────────────────────────
# PLANTILLA DE VARIABLES DE ENTORNO
#
# 1. Copia este archivo a uno llamado  .env   (sin .example)
#        cp .env.example .env
# 2. Pega TU api key en la línea del proveedor que vayas a usar.
# 3. NUNCA subas tu archivo .env a GitHub (ya está en .gitignore).
#
# Solo necesitas la key del proveedor que uses (mira config.yaml -> llm.model).
# ─────────────────────────────────────────────────────────────

# Claude / Anthropic  -> https://console.anthropic.com/
ANTHROPIC_API_KEY=tu_key_aqui

# OpenAI (ChatGPT)    -> https://platform.openai.com/api-keys
OPENAI_API_KEY=tu_key_aqui

# Google Gemini       -> https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_key_aqui
